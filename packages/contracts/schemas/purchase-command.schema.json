{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://restaurantos.local/schemas/purchase-command.schema.json",
  "title": "Purchase command",
  "oneOf": [
    { "$ref": "#/$defs/create" },
    { "$ref": "#/$defs/confirm" },
    { "$ref": "#/$defs/cancel" }
  ],
  "$defs": {
    "line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["presentation_id", "quantity", "unit_price", "discount", "tax"],
      "properties": {
        "presentation_id": { "type": "string", "format": "uuid" },
        "quantity": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]{1,6})?$" },
        "unit_price": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]{1,6})?$" },
        "discount": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]{1,6})?$" },
        "tax": { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]{1,6})?$" }
      }
    },
    "create": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_type", "command_id", "branch_id", "supplier_id", "document_type", "folio", "payment_method", "paid_from_cash", "lines"],
      "properties": {
        "command_type": { "const": "purchase.create" },
        "command_id": { "type": "string", "format": "uuid" },
        "branch_id": { "type": "string", "format": "uuid" },
        "supplier_id": { "type": "string", "format": "uuid" },
        "document_type": { "enum": ["invoice", "receipt", "ticket", "note"] },
        "folio": { "type": "string", "minLength": 1, "maxLength": 80 },
        "document_date": { "type": "string", "format": "date-time" },
        "payment_method": { "type": "string" },
        "paid_from_cash": { "type": "boolean" },
        "freight_total": { "const": "0" },
        "lines": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/line" } }
      }
    },
    "confirm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_type", "command_id", "purchase_id", "idempotency_key"],
      "properties": {
        "command_type": { "const": "purchase.confirm" },
        "command_id": { "type": "string", "format": "uuid" },
        "purchase_id": { "type": "string", "format": "uuid" },
        "idempotency_key": { "type": "string", "minLength": 8, "maxLength": 180 }
      }
    },
    "cancel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command_type", "command_id", "purchase_id", "reason"],
      "properties": {
        "command_type": { "const": "purchase.cancel" },
        "command_id": { "type": "string", "format": "uuid" },
        "purchase_id": { "type": "string", "format": "uuid" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 400 }
      }
    }
  }
}
